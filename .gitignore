# ===== WatchCore RTOS — ignore generated, downloaded, and local artifacts =====

# --- Third-party FreeRTOS kernel (auto-downloaded by setup.bat / setup.ps1) ---
# Pinned to V10.5.1; fetched on demand so it is not vendored into this repo.
/FreeRTOS-Kernel/

# --- C build output ---
/out/
build/
*.obj
*.exe
*.pdb
*.ilk
*.exp
*.lib
compile_commands.json

# --- Node / web ---
node_modules/
dist/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Runtime database (regenerated at runtime) ---
*.db
*.db-journal
*.db-wal
*.db-shm

# --- Logs / scratch ---
*.log
*.err

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# --- Local editor/tooling state (keep shared .vscode config, ignore personal) ---
.vscode/*.log
.idea/

# --- Environment / secrets (none in repo today; guard against future leaks) ---
.env
.env.*
!.env.example
*.local
